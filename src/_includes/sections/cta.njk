{#- SECTION: closing CTA strip. `sec` = home.cta. -#}
<section class="cta-strip">
  <h2 class="reveal">{{ sec.title | safe }}</h2>
  <p class="cta-strip-sub reveal reveal-delay-1">{{ sec.sub }}</p>
  <a href="{{ sec.buttonUrl }}" class="btn btn-black btn-lg magnetic reveal reveal-delay-2">{{ sec.button | safe }}</a>
</section>
