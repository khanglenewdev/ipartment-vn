{#- SECTION: finder banner. `sec` = home.finder. The button triggers
    the finder-quiz function (data-finder-open). -#}
<section class="finder-section">
  <div class="finder-banner">
    <div class="finder-banner-text">
      <strong>{{ sec.title }}</strong>
      <span>{{ sec.text }}</span>
    </div>
    <button type="button" class="btn btn-primary magnetic" data-finder-open>{{ sec.button }}</button>
  </div>
</section>
