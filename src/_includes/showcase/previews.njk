{#- ============================================================
    PREVIEW LIBRARY. One macro, prev(id), renders a small
    representative mock-up of each section variant. These show the
    COMPOSITION of each variant so a human (and a client) can see
    the difference. Production sections live in _includes/sections/.
    ============================================================ -#}

{% macro prev(id) %}
{%- if id == "hero-split" -%}
<div class="pv pv--dark">
  <div class="pv-nav"><span class="pv-logo">brand</span><span class="pv-navlinks">Rooms About Book</span></div>
  <div class="pv-row" style="flex:1;align-items:center">
    <div class="pv-col" style="display:flex;flex-direction:column;gap:6px">
      <div class="pv-h">Your second home<br>in <em>the city.</em></div>
      <div class="pv-line m"></div><div class="pv-line s"></div>
      <span class="pv-btn">Check my dates</span>
    </div>
    <div class="pv-card" style="max-width:42%">
      <div class="pv-line s" style="margin-bottom:6px"></div>
      <div class="pv-row" style="gap:5px;margin-bottom:6px"><div class="pv-line" style="height:14px;flex:1"></div><div class="pv-line" style="height:14px;flex:1"></div></div>
      <span class="pv-btn" style="width:100%;text-align:center">Book</span>
    </div>
  </div>
</div>
{%- elif id == "hero-centered" -%}
<div class="pv pv--paper pv-center">
  <span class="pv-pill">New</span>
  <div class="pv-h" style="font-size:22px">Clarity over <em>cleverness.</em></div>
  <div class="pv-line m" style="margin:0 auto"></div>
  <span class="pv-btn">Get started</span>
</div>
{%- elif id == "hero-fullbleed" -%}
<div class="pv pv--dark" style="padding:0">
  <div class="pv-bigimg"></div>
  <span class="pv-badge">Reserve</span>
  <div class="pv-overlay">
    <div class="pv-h" style="color:#fff">A place worth <em>staying.</em></div>
    <div class="pv-line m" style="background:#fff"></div>
    <span class="pv-btn">Book a table</span>
  </div>
</div>
{%- elif id == "vp-pillars" -%}
<div class="pv pv--paper">
  <div class="pv-h" style="font-size:14px">Why us</div>
  <div class="pv-grid3" style="flex:1">
    <div class="pv-card"><div class="pv-icon"></div><div class="pv-line l"></div><div class="pv-line s"></div></div>
    <div class="pv-card"><div class="pv-icon"></div><div class="pv-line l"></div><div class="pv-line s"></div></div>
    <div class="pv-card"><div class="pv-icon"></div><div class="pv-line l"></div><div class="pv-line s"></div></div>
  </div>
</div>
{%- elif id == "vp-rows" -%}
<div class="pv pv--paper">
  <div class="pv-h" style="font-size:14px">Built for <em>you</em></div>
  <div class="pv-row" style="align-items:flex-start"><span class="pv-num">01</span><div class="pv-col"><div class="pv-line m"></div><div class="pv-line l"></div></div></div>
  <div class="pv-row" style="align-items:flex-start"><span class="pv-num">02</span><div class="pv-col"><div class="pv-line m"></div><div class="pv-line l"></div></div></div>
  <div class="pv-row" style="align-items:flex-start"><span class="pv-num">03</span><div class="pv-col"><div class="pv-line m"></div><div class="pv-line s"></div></div></div>
</div>
{%- elif id == "vp-problem" -%}
<div class="pv pv--ink">
  <div class="pv-row" style="flex:1">
    <div class="pv-card" style="opacity:.7"><div class="pv-line s" style="background:#e5484d;opacity:.7"></div><div class="pv-line l"></div><div class="pv-line m"></div><div class="pv-line l"></div></div>
    <div class="pv-card"><span class="pv-acc"></span><div class="pv-line l"></div><div class="pv-line m"></div><div class="pv-line l"></div></div>
  </div>
</div>
{%- elif id == "ft-zigzag" -%}
<div class="pv pv--paper">
  <div class="pv-row" style="flex:1;align-items:center"><div class="pv-img"></div><div class="pv-col"><div class="pv-line m"></div><div class="pv-line l"></div><div class="pv-line s"></div></div></div>
  <div class="pv-row" style="flex:1;align-items:center"><div class="pv-col"><div class="pv-line m"></div><div class="pv-line l"></div></div><div class="pv-img"></div></div>
</div>
{%- elif id == "ft-bento" -%}
<div class="pv pv--ink">
  <div class="pv-row" style="flex:1">
    <div class="pv-card" style="flex:1.6;display:flex;flex-direction:column"><div class="pv-icon"></div><div class="pv-line l"></div><div class="pv-line m" style="margin-top:auto"></div></div>
    <div class="pv-col" style="display:flex;flex-direction:column;gap:7px">
      <div class="pv-card"><div class="pv-line m"></div></div>
      <div class="pv-card"><div class="pv-line s"></div></div>
    </div>
  </div>
</div>
{%- elif id == "ft-checklist" -%}
<div class="pv pv--paper">
  <div class="pv-row" style="flex:1;align-items:center">
    <div class="pv-col" style="display:flex;flex-direction:column;gap:6px">
      <div class="pv-row"><span class="pv-check">&check;</span><div class="pv-line l"></div></div>
      <div class="pv-row"><span class="pv-check">&check;</span><div class="pv-line m"></div></div>
      <div class="pv-row"><span class="pv-check">&check;</span><div class="pv-line l"></div></div>
      <div class="pv-row"><span class="pv-check">&check;</span><div class="pv-line s"></div></div>
    </div>
    <div class="pv-img"></div>
  </div>
</div>
{%- elif id == "pf-logobar" -%}
<div class="pv pv--ink pv-center">
  <div class="pv-stars">&#9733;&#9733;&#9733;&#9733;&#9733; 4.8</div>
  <div class="pv-row" style="gap:10px;margin-top:8px;opacity:.7">
    <span class="pv-pill">LOGO</span><span class="pv-pill">PRESS</span><span class="pv-pill">BRAND</span><span class="pv-pill">CO.</span>
  </div>
</div>
{%- elif id == "pf-cards" -%}
<div class="pv pv--paper">
  <div class="pv-grid3" style="flex:1">
    <div class="pv-card"><div class="pv-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div><div class="pv-line l"></div><div class="pv-line m"></div><div class="pv-line s" style="margin-top:8px;opacity:.4"></div></div>
    <div class="pv-card"><div class="pv-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div><div class="pv-line l"></div><div class="pv-line m"></div><div class="pv-line s" style="margin-top:8px;opacity:.4"></div></div>
    <div class="pv-card"><div class="pv-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div><div class="pv-line l"></div><div class="pv-line m"></div><div class="pv-line s" style="margin-top:8px;opacity:.4"></div></div>
  </div>
</div>
{%- elif id == "pf-undercta" -%}
<div class="pv pv--paper pv-center">
  <div class="pv-h" style="font-size:15px">Ready when you are</div>
  <span class="pv-btn">Get my quote</span>
  <div class="pv-stars" style="margin-top:6px">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
  <div class="pv-line s" style="margin:4px auto 0;opacity:.4"></div>
</div>
{%- elif id == "pr-tiers" -%}
<div class="pv pv--ink">
  <div class="pv-grid3" style="flex:1;align-items:center">
    <div class="pv-card"><div class="pv-line s"></div><div class="pv-h" style="font-size:13px">$9</div><div class="pv-line m"></div><span class="pv-btn ghost" style="margin-top:6px">Pick</span></div>
    <div class="pv-card" style="transform:scale(1.06);border-color:var(--brandc,#FFED00)"><span class="pv-pill" style="border-color:var(--brandc,#FFED00)">Popular</span><div class="pv-h" style="font-size:13px">$19</div><div class="pv-line m"></div><span class="pv-btn" style="margin-top:6px">Pick</span></div>
    <div class="pv-card"><div class="pv-line s"></div><div class="pv-h" style="font-size:13px">$39</div><div class="pv-line m"></div><span class="pv-btn ghost" style="margin-top:6px">Pick</span></div>
  </div>
</div>
{%- elif id == "pr-single" -%}
<div class="pv pv--paper pv-center">
  <div class="pv-card" style="max-width:60%;flex:none">
    <div class="pv-h" style="font-size:18px">$49<span style="font-size:9px">/mo</span></div>
    <div class="pv-row" style="justify-content:center;gap:4px"><span class="pv-check">&check;</span><div class="pv-line s"></div></div>
    <div class="pv-row" style="justify-content:center;gap:4px"><span class="pv-check">&check;</span><div class="pv-line s"></div></div>
    <span class="pv-btn" style="margin-top:8px">Start now</span>
  </div>
</div>
{%- elif id == "pr-table" -%}
<div class="pv pv--ink">
  <div class="pv-row" style="opacity:.6"><div class="pv-col"></div><div class="pv-col" style="text-align:center">A</div><div class="pv-col" style="text-align:center">B</div><div class="pv-col" style="text-align:center">C</div></div>
  {% for r in [1,2,3,4] %}<div class="pv-row pv-q" style="border-color:rgba(255,255,255,.12)"><div class="pv-col"><div class="pv-line s"></div></div><div class="pv-col" style="text-align:center"><span class="pv-check">&check;</span></div><div class="pv-col" style="text-align:center"><span class="pv-check">&check;</span></div><div class="pv-col" style="text-align:center;opacity:.3">&ndash;</div></div>{% endfor %}
</div>
{%- elif id == "faq-accordion" -%}
<div class="pv pv--paper">
  <div class="pv-h" style="font-size:14px">FAQ</div>
  <div class="pv-q"><div class="pv-line m"></div><span class="pv-caret">&#9662;</span></div>
  <div class="pv-q"><div class="pv-line l"></div><span class="pv-caret">&#9656;</span></div>
  <div class="pv-q"><div class="pv-line s"></div><span class="pv-caret">&#9656;</span></div>
  <div class="pv-q"><div class="pv-line m"></div><span class="pv-caret">&#9656;</span></div>
</div>
{%- elif id == "faq-twocol" -%}
<div class="pv pv--paper">
  <div class="pv-grid2" style="flex:1">
    <div><div class="pv-line s" style="opacity:.5"></div><div class="pv-line l"></div><div class="pv-line m"></div></div>
    <div><div class="pv-line s" style="opacity:.5"></div><div class="pv-line l"></div><div class="pv-line m"></div></div>
    <div><div class="pv-line s" style="opacity:.5"></div><div class="pv-line m"></div></div>
    <div><div class="pv-line s" style="opacity:.5"></div><div class="pv-line l"></div></div>
  </div>
</div>
{%- elif id == "ct-featured" -%}
<div class="pv pv--ink">
  <div class="pv-row" style="flex:1">
    <div class="pv-card" style="flex:1.5;display:flex;flex-direction:column"><div class="pv-img" style="min-height:55px"></div><div class="pv-line l" style="margin-top:6px"></div><div class="pv-line m"></div></div>
    <div class="pv-col" style="display:flex;flex-direction:column;gap:7px">
      <div class="pv-row" style="align-items:center"><div class="pv-img" style="width:28px;min-height:24px"></div><div class="pv-line m"></div></div>
      <div class="pv-row" style="align-items:center"><div class="pv-img" style="width:28px;min-height:24px"></div><div class="pv-line s"></div></div>
      <div class="pv-row" style="align-items:center"><div class="pv-img" style="width:28px;min-height:24px"></div><div class="pv-line m"></div></div>
    </div>
  </div>
</div>
{%- elif id == "ct-cards" -%}
<div class="pv pv--paper">
  <div class="pv-grid3" style="flex:1">
    <div class="pv-card" style="padding:0;overflow:hidden"><div class="pv-img" style="border-radius:0"></div><div style="padding:6px"><div class="pv-line l"></div><div class="pv-line s"></div></div></div>
    <div class="pv-card" style="padding:0;overflow:hidden"><div class="pv-img" style="border-radius:0"></div><div style="padding:6px"><div class="pv-line l"></div><div class="pv-line s"></div></div></div>
    <div class="pv-card" style="padding:0;overflow:hidden"><div class="pv-img" style="border-radius:0"></div><div style="padding:6px"><div class="pv-line l"></div><div class="pv-line s"></div></div></div>
  </div>
</div>
{%- elif id == "loc-split" -%}
<div class="pv pv--ink">
  <div class="pv-row" style="flex:1">
    <div class="pv-col" style="display:flex;flex-direction:column;gap:6px"><div class="pv-line s" style="opacity:.5"></div><div class="pv-line m"></div><div class="pv-line l"></div><span class="pv-btn" style="margin-top:4px">Directions</span></div>
    <div class="pv-img" style="background:repeating-linear-gradient(45deg,#243,#243 6px,#1c1c1c 6px,#1c1c1c 12px)"></div>
  </div>
</div>
{%- elif id == "loc-card" -%}
<div class="pv pv--paper pv-center">
  <div class="pv-card" style="max-width:62%;flex:none"><div class="pv-h" style="font-size:13px">Open today</div><div class="pv-line s" style="margin:0 auto"></div><div class="pv-line m" style="margin:4px auto"></div><span class="pv-btn">Call now</span></div>
</div>
{%- elif id == "cta-banner" -%}
<div class="pv pv--dark pv-center">
  <div class="pv-h" style="font-size:20px;color:#fff">Move in <em>today.</em></div>
  <span class="pv-btn" style="padding:7px 16px">Book my stay &#8594;</span>
</div>
{%- elif id == "cta-reassure" -%}
<div class="pv pv--paper pv-center">
  <div class="pv-h" style="font-size:16px">Start your consultation</div>
  <span class="pv-btn">Book my consult</span>
  <div class="pv-line s" style="margin:6px auto 0;opacity:.45"></div>
  <span style="font-size:8px;opacity:.6">No payment until confirmed</span>
</div>
{%- elif id == "cap-inline" -%}
<div class="pv pv--paper pv-center">
  <div class="pv-h" style="font-size:14px">Get the guide</div>
  <div class="pv-card" style="max-width:70%;flex:none"><div class="pv-line l" style="height:13px;margin-bottom:5px;opacity:.25"></div><span class="pv-btn" style="width:100%;text-align:center">Send it to me</span><div style="font-size:7px;opacity:.55;margin-top:4px">No spam. Unsubscribe anytime.</div></div>
</div>
{%- elif id == "cap-convo" -%}
<div class="pv pv--ink">
  <div class="pv-line s" style="opacity:.4">Step 2 of 3</div>
  <div class="pv-card" style="align-self:flex-start;max-width:75%">When would you like to stay?</div>
  <div class="pv-row" style="gap:6px"><span class="pv-pill">This week</span><span class="pv-pill">This month</span><span class="pv-pill">Later</span></div>
  <span class="pv-btn" style="align-self:flex-end;margin-top:auto">Next</span>
</div>
{%- else -%}
<div class="pv pv--ink pv-center"><div class="pv-line m" style="margin:0 auto"></div></div>
{%- endif -%}
{% endmacro %}
